{
  "_meta": {
    "description": "Pre-built page skeletons by domain pattern. Claude copies the closest match and customizes instead of writing from scratch. Each template specifies which components to use and how to wire them.",
    "lastUpdated": "2026-03-22",
    "totalRallies": 0
  },
  "dashboard": {
