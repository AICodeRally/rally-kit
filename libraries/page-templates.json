  "list-page": {
    "description": "Browse/list page — DataTable or ListItem based",
    "components": ["PageHeader", "DataTable", "ListItem"],
    "columnSets": {
      "customers": ["Name", "Email", "Phone", "Status", "Joined"],
      "orders": ["Order #", "Customer", "Date", "Total", "Status"],
      "products": ["Name", "Category", "Price", "Stock", "Status"],
      "appointments": ["Date", "Time", "Customer", "Service", "Status"],
      "listings": ["Title", "Seller", "Price", "Category", "Posted"],
      "applications": ["Company", "Role", "Date Applied", "Status", "Next Step"],
      "courses": ["Course", "Professor", "Time", "Grade", "Status"],
      "workouts": ["Date", "Type", "Duration", "Calories", "Notes"]
    }
  },
  "detail-page": {
    "description": "Single item view — DetailCard + related data",
    "components": ["PageHeader", "DetailCard", "ListItem", "StatCard"],
    "patterns": {
      "customer-detail": { "sections": ["Contact Info", "Recent Orders", "Notes"] },
      "product-detail": { "sections": ["Product Info", "Pricing", "Inventory", "Reviews"] },
      "listing-detail": { "sections": ["Listing Info", "Seller Profile", "Similar Items"] },
      "profile": { "sections": ["Personal Info", "Stats", "Activity", "Settings"] }
    }
  },
  "form-page": {
    "description": "Create/edit page — FormCard based",
    "components": ["PageHeader", "FormCard"],
    "fieldSets": {
      "customer": ["Name (text)", "Email (email)", "Phone (tel)", "Notes (textarea)"],
      "product": ["Name (text)", "Category (select)", "Price (number)", "Description (textarea)", "In Stock (select)"],
      "appointment": ["Customer (select)", "Service (select)", "Date (date)", "Time (select)", "Notes (textarea)"],
      "listing": ["Title (text)", "Category (select)", "Price (number)", "Description (textarea)", "Photos (file)"]
    }
  },
