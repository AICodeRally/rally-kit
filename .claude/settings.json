{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npx next*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)"
    ]
  }
}
